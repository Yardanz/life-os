generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum StatType {
  ENERGY
  FOCUS
  DISCIPLINE
  FINANCE
  GROWTH
}

enum FactorType {
  SLEEP
  WORKOUT
  DEEP_WORK
  LEARNING
  MONEY_DELTA
  STRESS
  OVERLOAD
  MOMENTUM
}

enum SystemStatus {
  STABLE
  WARNING
  CRITICAL
}

enum UserPlan {
  FREE
  PRO
}

enum BillingPlanCode {
  OPERATOR_MONTHLY
  OPERATOR_YEARLY
}

enum BillingOrderStatus {
  CREATED
  INVOICE_CREATED
  PENDING
  PARTIAL
  PAID
  FAILED
  CANCELED
  REFUNDED
}

enum EntitlementKey {
  OPERATOR_LICENSE
}

enum EntitlementStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

model User {
  id               String             @id @default(cuid())
  email            String?            @unique
  emailVerified    DateTime?
  image            String?
  name             String?
  role             String             @default("USER")
  plan             UserPlan           @default(FREE)
  onboardingCompleted Boolean         @default(false)
  welcomeModalSeen Boolean            @default(false)
  calibrationCheckinsNeeded Int       @default(7)
  calibrationCheckinsDone Int         @default(0)
  adaptiveRiskOffset Float            @default(0)
  adaptiveRecoveryOffset Float        @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  accounts         Account[]
  sessions         Session[]
  authenticators   Authenticator[]
  dailyCheckIns    DailyCheckIn[]
  statSnapshots    StatSnapshot[]
  statContributions StatContribution[]
  xpEvents         XpEvent[]
  levelSnapshots   LevelSnapshot[]
  userAchievements UserAchievement[]
  antiChaosPlans   AntiChaosPlan[]
  bioStateSnapshots BioStateSnapshot[]
  scenarioSnapshots ScenarioSnapshot[]
  protocolRuns      ProtocolRun[]
  systemSnapshots   SystemSnapshot[]
  billingOrders     BillingOrder[]
  entitlement       Entitlement?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

model DailyCheckIn {
  id            String       @id @default(cuid())
  userId        String
  date          DateTime     @db.Date
  bedtimeMinutes Int?
  wakeTimeMinutes Int?
  systemStatus  SystemStatus
  mood          Int?
  stressLevel   Int?
  energyLevel   Int?
  notes         String?
  configVersion Int
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  config        WeightConfig @relation(fields: [configVersion], references: [configVersion], onDelete: Restrict)

  @@unique([userId, date])
  @@index([date])
}

model StatSnapshot {
  id             String             @id @default(cuid())
  userId         String
  date           DateTime           @db.Date
  health         Decimal            @db.Decimal(5, 2)
  relationships  Decimal            @db.Decimal(5, 2)
  career         Decimal            @db.Decimal(5, 2)
  finance        Decimal            @db.Decimal(5, 2)
  personalGrowth Decimal            @db.Decimal(5, 2)
  lifeScore      Decimal            @db.Decimal(5, 2)
  systemStatus   SystemStatus
  configVersion  Int
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  config         WeightConfig       @relation(fields: [configVersion], references: [configVersion], onDelete: Restrict)
  contributions  StatContribution[]

  @@unique([userId, date])
  @@index([date])
}

model StatContribution {
  id              String       @id @default(cuid())
  userId          String
  snapshotId      String
  date            DateTime     @db.Date
  statType        StatType
  factorType      FactorType
  contribution    Decimal      @db.Decimal(8, 3)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshot        StatSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@unique([userId, date, statType, factorType])
  @@index([userId, date])
  @@index([snapshotId])
}

model WeightConfig {
  id              String          @id @default(cuid())
  configVersion   Int             @unique
  lagDays         Int             @default(0)
  decayDays       Int             @default(7)
  momentumWeight  Float           @default(0.15)
  healthWeight    Decimal         @db.Decimal(5, 2)
  relationWeight  Decimal         @db.Decimal(5, 2)
  careerWeight    Decimal         @db.Decimal(5, 2)
  financeWeight   Decimal         @db.Decimal(5, 2)
  growthWeight    Decimal         @db.Decimal(5, 2)
  reserveSleepGain Float          @default(0.06)
  reserveWorkCost Float           @default(0.03)
  reserveStressCost Float         @default(0.04)
  fatigueCarry    Float           @default(0.92)
  fatigueWorkGain Float           @default(0.025)
  fatigueStressGain Float         @default(0.03)
  fatigueSleepRecovery Float      @default(0.045)
  strainCarry     Float           @default(0.90)
  strainFatigueWeight Float       @default(0.45)
  overloadLevel1Threshold Float   @default(45)
  overloadLevel2Threshold Float   @default(70)
  overloadRecoverThreshold Float  @default(35)
  baseFocus       Float           @default(50)
  focusFromEnergy Float           @default(0.11)
  focusFromFatigue Float          @default(0.09)
  focusFromStress Float           @default(0.12)
  optLoadMin      Float           @default(0.35)
  optLoadMax      Float           @default(0.75)
  adaptGain       Float           @default(0.03)
  burnoutPenalty  Float           @default(0.06)
  disciplineCarry Float           @default(0.96)
  debtCarry       Float           @default(0.96)
  debtRecoveryFactor Float        @default(12)
  adaptiveCarry   Float           @default(0.98)
  bufferGain      Float           @default(0.6)
  bufferCarry     Float           @default(0.65)
  bufferSpendMax  Float           @default(35)
  reserveFromBuffer Float         @default(0.35)
  fatigueFromBuffer Float         @default(0.45)
  stressCarry     Float           @default(0.75)
  stressGain      Float           @default(0.9)
  stressRecovery  Float           @default(0.35)
  trainingIn      Float           @default(35)
  trainingCarry   Float           @default(0.70)
  trainingSpendMax Float          @default(20)
  trainingReserveBonus Float      @default(0.18)
  trainingDisciplineBonus Float   @default(0.28)
  trainingAdaptiveBonus Float     @default(0.12)
  workoutSameDayCostReserve Float @default(8)
  workoutSameDayCostFatigue Float @default(6)
  sympCarry       Float           @default(0.78)
  paraCarry       Float           @default(0.78)
  sympFromStress  Float           @default(0.55)
  sympFromLoad    Float           @default(0.35)
  sympFromStrain  Float           @default(0.25)
  paraFromSleep   Float           @default(0.45)
  paraFromRecovery Float          @default(0.35)
  paraFromCircadian Float         @default(0.25)
  paraSuppressedByStressLoad Float @default(0.25)
  isActive        Boolean         @default(true)
  effectiveFrom   DateTime?       @db.Date
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  dailyCheckIns   DailyCheckIn[]
  statSnapshots   StatSnapshot[]
}

model BioStateSnapshot {
  id               String   @id @default(cuid())
  userId           String
  date             DateTime @db.Date
  energyReserve    Float
  cognitiveFatigue Float
  strainIndex      Float
  overloadLevel    Int
  recoveryDebt     Float          @default(0)
  adaptiveCapacity Float          @default(50)
  sleepBuffer      Float          @default(0)
  circadianAlignment Float        @default(70)
  sleepRegularity  Float          @default(70)
  stressLoad       Float          @default(20)
  trainingBuffer   Float          @default(0)
  homeostasisBias  Float          @default(20)
  cognitiveSaturation Float       @default(0)
  sympatheticDrive Float          @default(40)
  parasympatheticDrive Float      @default(40)
  autonomicBalance Float          @default(50)
  hormeticSignal    Float         @default(20)
  overstressSignal  Float         @default(10)
  burnoutRiskIndex  Float         @default(15)
  resilienceIndex   Float         @default(50)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model XpEvent {
  id          String    @id @default(cuid())
  userId      String
  date        DateTime  @db.Date
  amount      Int
  reason      String
  source      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([date])
}

model LevelSnapshot {
  id            String    @id @default(cuid())
  userId        String
  date          DateTime  @db.Date
  level         Int
  currentXp     Int
  totalXp       Int
  xpToNextLevel Int
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([date])
}

model Achievement {
  id               String            @id @default(cuid())
  code             String            @unique
  title            String
  description      String?
  xpReward         Int               @default(0)
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  earnedDate    DateTime    @db.Date
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Restrict)

  @@unique([userId, achievementId])
  @@index([userId, earnedDate])
}

model AntiChaosPlan {
  id           String       @id @default(cuid())
  userId       String
  date         DateTime     @db.Date
  systemStatus SystemStatus
  reasons      String[]
  actionItems  String[]
  isResolved   Boolean      @default(false)
  resolvedDate DateTime?    @db.Date
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, isResolved])
}

model ScenarioSnapshot {
  id                    String   @id @default(uuid())
  userId                String
  createdAt             DateTime @default(now())
  name                  String?
  horizonDays           Int      @default(30)
  tags                  String?
  baseDateISO           String
  source                String
  inputModifiers        Json
  projectionResult      Json
  patternContext        Json
  calibrationConfidence Float
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ProtocolRun {
  id            String   @id @default(uuid())
  userId        String
  createdAt     DateTime @default(now())
  horizonHours  Int
  mode          String   @default("STANDARD")
  guardrailState String
  confidence    Float
  inputs        Json
  protocol      Json
  appliedAt     DateTime?
  outcome       Json?
  integrityAtEnd Json?
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model SystemSnapshot {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  createdAt DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?
  payload   Json
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model BillingPlan {
  id            String          @id @default(cuid())
  code          BillingPlanCode @unique
  title         String
  priceAmount   Decimal         @db.Decimal(18, 2)
  priceCurrency String
  periodDays    Int
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model BillingOrder {
  id                String               @id @default(cuid())
  userId            String
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  planCode          BillingPlanCode
  status            BillingOrderStatus   @default(CREATED)
  amount            Decimal              @db.Decimal(18, 2)
  currency          String
  provider          String               @default("NOWPAYMENTS")
  providerInvoiceId String?
  invoiceUrl        String?
  payAddress        String?
  payCurrency       String?
  paidAt            DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  events            BillingPaymentEvent[]
  entitlements      Entitlement[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model BillingPaymentEvent {
  id              String       @id @default(cuid())
  orderId          String
  order            BillingOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  providerEventId  String?
  statusRaw        String
  signature        String?
  payload          Json
  receivedAt       DateTime    @default(now())

  @@index([orderId, receivedAt])
}

model Entitlement {
  id            String            @id @default(cuid())
  userId        String            @unique
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  key           EntitlementKey
  status        EntitlementStatus @default(ACTIVE)
  startsAt      DateTime
  expiresAt     DateTime
  sourceOrderId String?
  sourceOrder   BillingOrder?     @relation(fields: [sourceOrderId], references: [id], onDelete: SetNull)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([key, status])
  @@index([expiresAt])
}
